# Server
NODE_ENV=development
PORT=8080

# Public app URL used when constructing absolute links behind the reverse proxy.
# Example: https://your-app.mctai.app
SELF_URL=

# Optional explicit origin for future browser-origin checks.
# The deployment platform may inject this as the app's public URL.
ALLOWED_CORS_ORIGIN=

# Ideavibes email service. Server-side only; never expose the token to client code.
# If MCTAI_EMAIL_URL is unset, email sending should be treated as unprovisioned.
MCTAI_EMAIL_URL=
MCTAI_EMAIL_APP_TOKEN=
